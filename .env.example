# Azure OpenAI (required)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4o
AZURE_OPENAI_DEPLOYMENT_EMBED=text-embedding-3-small

# Langfuse (required for observability + prompts + evals + cache)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_POLICY=refund_policy_v1

# SQLite path (relative to repo root)
SQLITE_PATH=data/state.db

# Agent behavior
AGENT_LOG_LEVEL=INFO
AUTO_APPROVAL_CAP_STANDARD_USD=200
AUTO_APPROVAL_CAP_VIP_USD=500
COMPACTION_TOKEN_THRESHOLD=4000

# Frontend
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# Hugging Face Spaces (set in HF UI when deploying; leave blank locally)
SPACE_ID=
